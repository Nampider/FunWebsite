# Example only. Enter real values in the Render dashboard; do not commit them.
CHAT_CHRIS_PASSWORD=replace-with-a-long-unique-password
CHAT_AUDREY_PASSWORD=replace-with-a-different-long-unique-password

# Use the frontend origin only: no path and no trailing slash.
CHAT_FRONTEND_ORIGIN=https://your-frontend.onrender.com

# Separate onrender.com services are cross-site.
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=none
FORWARD_HEADERS_STRATEGY=framework
CHAT_DEBUG_ENDPOINTS_ENABLED=false
